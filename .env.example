# Copy to .env and fill in. Do not commit .env.

# ============================================================
# Core (required)
# ============================================================

# Absolute path to the Obsidian vault root.
VAULT_PATH="/home/lordmuffin/Documents/Notes"

# tmux session name that owns the headless Claude Code process for Kai.
TMUX_SESSION="jarvis"

# Working directory Claude Code is launched from. Its CLAUDE.md becomes
# the Jarvis routing identity. Leave as-is unless you've moved the
# Jarvis project folder inside the vault.
JARVIS_PROJECT_DIR="${VAULT_PATH}/10 Projects/Jarvis"

# 1Password secret reference for the Kai bot token (Channels plugin).
# Resolved at start time via `op read` — never written to disk.
OP_BOT_TOKEN_REF="op://Jarvis/jarvis-router-bot/bot_token"

# How long start-jarvis.sh waits for Claude Code to become responsive
# inside the tmux pane before giving up (seconds).
STARTUP_TIMEOUT="30"

# Telegram chat_id receiving workload start/stop notifications. Use
# `@userinfobot` in Telegram to discover your own id.
TELEGRAM_CHAT_ID="7024287135"

# ============================================================
# Forge Agent (required if forge-watcher.service is enabled)
# ============================================================

# 1Password secret reference for the ForgeBot token (separate Telegram
# bot identity from Kai). Create with BotFather, store with:
#   op item create --category login --title "Jarvis ForgeBot" --vault Personal token=<token>
FORGE_OP_BOT_TOKEN_REF="op://Personal/Jarvis ForgeBot/token"

# tmux session name for the Forge agent. Default: "forge".
# FORGE_TMUX_SESSION="forge"

# ============================================================
# Gaming PC GPU inference (optional)
# ============================================================
# AMD Radeon RX 9070 XT 16GB (gfx1201, RDNA 4) running CachyOS + Ollama
# with ROCm 6.3+. SSH key auth from Jarvis host to gaming PC required.

GAMING_PC_HOST=                              # hostname or IP, e.g. 192.168.1.x
GAMING_PC_SSH_KEY=                           # path to SSH private key, e.g. ~/.ssh/id_ed25519

# 16GB VRAM limit — 70B models do NOT fit. Recommended targets:
#   qwen2.5-coder:14b  → ~9GB Q4, best for forge/code (default)
#   llama3.1:8b-q8     → ~8.5GB, best general-assistant quality that fits
#   qwen2.5:3b         → ~2GB, near-instant for classification only
GAMING_PC_INFERENCE_MODEL="qwen2.5-coder:14b"

# ============================================================
# Vast.ai cloud GPU (optional — only needed for batch jobs > 30 min)
# ============================================================
# Get from https://vast.ai/console → Account → API Key.
# Cost guardrail: cloud GPU is for batch (transcription jobs, long forge
# runs) — not for interactive sessions. Always destroy when done.

VAST_API_KEY=

# ============================================================
# Voice stack (LXC 400 on Proxmox)
# ============================================================
# start-voice.sh controls the Kokoro + XTTS docker stack inside LXC 400
# via `pct exec` from the Proxmox host. Requires SSH key auth to Proxmox.

PROXMOX_HOST="192.168.1.101"
PROXMOX_SSH_KEY=                             # optional explicit key path
VOICE_LXC_ID="400"
VOICE_COMPOSE_DIR="/opt/voice"
# VOICE_HOST defaults to PROXMOX_HOST; override if voice ports are
# exposed on a different address.
# VOICE_HOST=
KOKORO_PORT="8880"
XTTS_PORT="8881"
