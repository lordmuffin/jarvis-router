# Copy to .env and fill in. Do not commit .env.

# Absolute path to the Obsidian vault root.
VAULT_PATH="/home/lordmuffin/Documents/Notes"

# tmux session name that owns the headless Claude Code process.
TMUX_SESSION="jarvis"

# Working directory Claude Code is launched from. Its CLAUDE.md becomes
# the Jarvis routing identity. Leave as-is unless you've moved the
# Jarvis project folder inside the vault.
JARVIS_PROJECT_DIR="${VAULT_PATH}/10 Projects/Jarvis"

# 1Password secret reference for the Telegram bot token used by the
# Channels plugin. Resolved at start time via `op read` — never written
# to disk.
OP_BOT_TOKEN_REF="op://Jarvis/jarvis-router-bot/bot_token"

# How long start-jarvis.sh waits for Claude Code to become responsive
# inside the tmux pane before giving up (seconds).
STARTUP_TIMEOUT="30"

# ---- Forge auto-dispatch ---------------------------------------------------
# Forge is the on-demand work agent. Kai appends tasks to forge-queue.md;
# the forge-watcher daemon notices and fires off a Forge session. Each
# session runs to completion (oneshot) and is not auto-restarted.

# tmux session name for the Forge agent. Kept distinct from TMUX_SESSION
# so Kai and Forge can run side by side.
FORGE_TMUX_SESSION="forge"

# Working directory for the Forge Claude Code process. Defaults to the
# vault root so Forge can navigate the full vault while it works.
FORGE_PROJECT_DIR="${VAULT_PATH}"

# Markdown file the watcher tails. Items under "## Active" trigger a
# session; items under "## Paused" are the parking lot for incomplete
# work after a crash.
FORGE_QUEUE_PATH="${VAULT_PATH}/10 Projects/Jarvis/Infrastructure/forge-queue.md"

# Optional system prompt file. If present, passed to claude via
# --system-prompt; if missing, Forge falls back to CLAUDE.md in
# FORGE_PROJECT_DIR.
FORGE_SYSTEM_PROMPT="${VAULT_PATH}/10 Projects/Jarvis/Infrastructure/forge-system-prompt.md"

# 1Password secret reference for ForgeBot's Telegram bot token. Leave
# empty to skip the token check (useful before BotFather setup).
# TODO confirm 1Password path for ForgeBot once the item exists. The Kai
# bot lives at op://Jarvis/jarvis-router-bot/bot_token; mirror that
# convention (e.g. op://Jarvis/jarvis-router-forgebot/bot_token).
FORGE_OP_BOT_TOKEN_REF=""

# Telegram chat id that receives crash notifications. Default is
# Andrew's DM with ForgeBot.
FORGE_TELEGRAM_CHAT_ID="7024287135"

# Seconds between queue checks when inotifywait is unavailable
# (degraded poll mode).
FORGE_WATCHER_POLL_INTERVAL="30"

# How long start-forge.sh waits for the tmux session to come up before
# considering the launch failed (seconds).
FORGE_STARTUP_TIMEOUT="10"
